---
interface Props {
  title: string;
  description: string;
  link: string;
  img: ImageMetadata;
}

const { title, description, img, link } = Astro.props;
---

<a class="card" href={link}>
  <img class="img" src={img.src} alt={title} />
  <div class="content">
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</a>

<style>
  .card {
    background-color: var(--background-color-2);
    border: var(--border);
    border-radius: 4px;
    color: var(--text-color);
    overflow: hidden;
    transition: border-color ease-in-out 0.25s;
  }

  .img {
    width: 100%;
    height: auto;
  }

  .card:hover {
    border-color: var(--accent-color);
    cursor: pointer;
    text-decoration: none;
  }

  .content {
    padding: 1rem;
  }
</style>

